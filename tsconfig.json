{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "types": ["bun"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "lib": ["ESNext"]
  },
  "include": ["generator.ts", "benchmark.ts", "explore.ts", "core.ts", "ui.ts", "markdown.d.ts", "scripts"]
}
